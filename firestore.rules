rules_version = '2';
// Règles Firestore pour Hna Hofra.
// L'app est anonyme (aucune connexion) : tout le monde peut lire et signaler.
// La suppression est interdite ; les documents expirés (réparés > 10 jours) sont
// simplement masqués côté application.
//
// Collez ces règles dans : Firebase Console > Firestore Database > Règles > Publier.
service cloud.firestore {
  match /databases/{database}/documents {
    match /potholes/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
  }
}
